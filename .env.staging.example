STAGING_APP_URL=https://staging.redist.ae
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this to browsers, mobile apps, screenshots, or Git.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only lead notifications. Never expose or commit a real API key.
RESEND_API_KEY=
LEAD_NOTIFICATION_TO=founder@example.com
LEAD_NOTIFICATION_FROM="ReDist Leads <notifications@redistribut.com>"

# Optional. Defaults to ReDistPilot!2026 if omitted.
STAGING_PILOT_PASSWORD=

# Set true for the final pre-invite gate.
STAGING_REQUIRE_LIVE=true
